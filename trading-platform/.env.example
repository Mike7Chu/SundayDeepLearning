# ===== 공통 =====
# API 호스트 포트 (8000이 이미 점유된 경우 변경. OMV 등과 충돌 회피용 기본 8090)
API_PORT=8090

# Redis
REDIS_URL=redis://redis:6379/0

# 자산 목표(원) — 홈 대시보드 진행률 (기본 100억)
# TARGET_ASSET_KRW=10000000000

# ===== 한국투자증권 KIS (주식 시세·일봉·배당) =====
# KIS_APP_KEY=
# KIS_APP_SECRET=
# KIS_ACCOUNT=
# KIS_PAPER=true
# STOCK_INTERVAL_SEC=15
# STOCK_HISTORY_INTERVAL_SEC=21600

# ===== 텔레그램 (일일 브리핑·알림) =====
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# BRIEFING_INTERVAL_SEC=86400
# BRIEFING_DRIP_BUDGET=0     # 배당 정기적립 월예산(원). 0=미사용

# ===== AI 4대 거장 리서치 — 둘 중 하나 =====
# (A) 구독 무과금: Claude Code 설치+로그인 후 아래 ON (API 키 불필요, 구독 한도 내)
# RESEARCH_USE_CLI=false
# RESEARCH_CLI_BIN=claude
# (B) API 종량과금: console.anthropic.com 키 (구독과 별도 결제)
# ANTHROPIC_API_KEY=
# 공통
# RESEARCH_MODEL=claude-opus-4-8
# RESEARCH_INTERVAL_SEC=86400
