# ===== 공통 =====
# API 호스트 포트 (8000이 이미 점유된 경우 변경. OMV 등과 충돌 회피용 기본 8090)
API_PORT=8090

# Redis
REDIS_URL=redis://redis:6379/0

# 자산 목표(원) — 홈 대시보드 진행률 (기본 100억)
# TARGET_ASSET_KRW=10000000000

# ===== 한국투자증권 KIS (주식 시세·일봉·배당) =====
# KIS_APP_KEY=
# KIS_APP_SECRET=
# KIS_ACCOUNT=
# KIS_PAPER=true
# KIS_QUOTE_REAL=true    # 기본 true=시세/일봉/배당을 실전 도메인으로(예탁원 배당 등 완전). 실전 앱키 필요. 모의 앱키만 있으면 false
# STOCK_INTERVAL_SEC=15
# STOCK_HISTORY_INTERVAL_SEC=21600

# ===== 토스증권 Open API (실보유·매수여력·실주문) — developers.tossinvest.com =====
# TOSS_CLIENT_ID=
# TOSS_CLIENT_SECRET=
# TOSS_ACCOUNT_SEQ=          # 선택. 비우면 /accounts 대표계좌 자동탐색
# TOSS_INTERVAL_SEC=30       # 보유/잔고 수집 주기
# --- 실매매 게이트 (기본 잠금 — 실제 돈이 나감) ---
# TOSS_TRADING_ENABLED=false # true라야 대시보드 주문 버튼·주문 API 허용
# TOSS_MAX_ORDER_KRW=100000  # 주문당 안전 상한(소액 실전)

# ===== DART 전자공시 (무료 키: opendart.fss.or.kr) =====
# DART_API_KEY=
# DART_INTERVAL_SEC=30        # 공시 폴링 주기(속도)
# DART_WATCH_ALL=false        # true=전 종목 공시, false=관심종목만

# ===== 전체 시장 스크리너(유니버스 펀더멘털 수집) =====
# MARKET_SCAN_INTERVAL_SEC=3600   # 유니버스 1바퀴 목표 주기
# MARKET_BATCH=60                 # 사이클당 조회 종목 수
# MARKET_UNIVERSE_MAX=900         # 유니버스 상한

# ===== 매매 엔진(멍거 리스크 실드) — 기본 10분 주기, 주문은 내지 않음 =====
# ENGINE_INTERVAL_SEC=600
# MDD_LIMIT_PCT=15        # 최고점 대비 -15% → 자동 매수 잠금(서킷 브레이커)
# MAX_STOCK_PCT=5         # 단일 종목 최대 매수금액 = 자산의 5%
# CASH_FLOOR_PCT=25       # 현금 비중 25% 미만이면 매수 시그널 무시
# BUY_SCORE_MIN=70        # 2단계 필터 최종 점수 컷
# INVERSION_MAX_PER_CYCLE=5

# ===== 텔레그램 (일일 브리핑·알림) =====
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# BRIEFING_INTERVAL_SEC=86400
# BRIEFING_DRIP_BUDGET=0     # 배당 정기적립 월예산(원). 0=미사용

# ===== AI 4대 거장 리서치 — 둘 중 하나 =====
# (A) 구독 무과금: Claude Code 설치+로그인 후 아래 ON (API 키 불필요, 구독 한도 내)
# RESEARCH_USE_CLI=false
# RESEARCH_CLI_BIN=claude
# (B) API 종량과금: console.anthropic.com 키 (구독과 별도 결제)
# ANTHROPIC_API_KEY=
# 공통
# RESEARCH_MODEL=claude-opus-4-8
# RESEARCH_INTERVAL_SEC=86400
