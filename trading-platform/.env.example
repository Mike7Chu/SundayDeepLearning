# ===== 공통 =====
# API 호스트 포트 (8000이 이미 점유된 경우 변경. OMV 등과 충돌 회피용 기본 8090)
API_PORT=8090

# Redis
REDIS_URL=redis://redis:6379/0

# 자산 목표(원) — 홈 대시보드 진행률 (기본 100억)
# TARGET_ASSET_KRW=10000000000

# ===== 한국투자증권 KIS (주식 시세·일봉·배당) =====
# KIS_APP_KEY=            # 주문 계좌용 앱키(모의계좌면 '모의 앱키')
# KIS_APP_SECRET=
# KIS_ACCOUNT=
# KIS_PAPER=true          # 주문 도메인: true=모의(가짜 돈), false=실전
# --- 이중 앱키(권장): 모의키로 주문 + 실전키로 조회 ---
# 실전 조회 앱키를 넣으면 시세·재무·해외를 '실전 도메인(안정)'으로 → 모의 도메인 500/노이즈 사라짐.
# 주문은 여전히 KIS_PAPER=true면 모의로 나감(시세만 실전). 없으면 KIS_APP_KEY로 조회.
# KIS_REAL_APP_KEY=
# KIS_REAL_APP_SECRET=
# KIS_QUOTE_REAL=true    # (실전 조회키 없을 때만 의미) true=조회를 실전 도메인으로. 모의 앱키만 있으면 false
# STOCK_INTERVAL_SEC=15
# STOCK_HISTORY_INTERVAL_SEC=21600
# KIS_WS_ENABLED=true       # 장중 웹소켓 실시간 체결가(관심∪보유 41종목). false=REST 폴링만
# --- 미장 자동매매 (KIS 해외주식 — 모의 지원. 국내=가치, 미국=모멘텀 스윙) ---
# US_AUTO_ENABLED=false     # true+KIS_TRADING_ENABLED+AUTO_TRADE_ENABLED라야 미장 자동매수
# KIS_US_EXCHANGE_MAP=      # 거래소 오분류 교정: "PLTR:NASD,SNOW:NYSE"(모의 테스트에서 거부되면 추가)
# STREAM_INTERVAL_SEC=2     # 대시보드 SSE 푸시 주기(변경분만)
# GUARD_INTERVAL_SEC=20     # 엔진 목표가/손절 실시간 감시 주기

# ===== 토스증권 Open API (실보유·매수여력·실주문) — developers.tossinvest.com =====
# TOSS_CLIENT_ID=
# TOSS_CLIENT_SECRET=
# TOSS_ACCOUNT_SEQ=          # 선택. 비우면 /accounts 대표계좌 자동탐색
# TOSS_INTERVAL_SEC=30       # 보유/잔고 수집 주기
# TOSS_MIN_INTERVAL_SEC=0.3  # 요청 사이 최소 간격(레이트리밋 방어, 전 루프 공유). 한도 자주 걸리면 0.5로
# TOSS_MAX_RETRY=4           # rate-limit/invalid-token 시 백오프 재시도 횟수
# --- 실매매 게이트 (기본 잠금 — 실제 돈이 나감) ---
# TOSS_TRADING_ENABLED=false # true라야 대시보드 주문 버튼·주문 API 허용
# TOSS_MAX_ORDER_KRW=100000  # 주문당 안전 상한(소액 실전)

# ===== DART 전자공시 (무료 키: opendart.fss.or.kr) =====
# DART_API_KEY=
# DART_INTERVAL_SEC=30        # 공시 폴링 주기(속도)
# DART_WATCH_ALL=false        # true=전 종목 공시, false=관심종목만

# ===== 전체 시장 스크리너(유니버스 펀더멘털 수집) =====
# MARKET_SCAN_INTERVAL_SEC=3600   # 유니버스 1바퀴 목표 주기
# MARKET_BATCH=60                 # 사이클당 조회 종목 수
# MARKET_UNIVERSE_MAX=4000        # 유니버스 상한(코스피+코스닥 전 종목. 900 등 낮은 값이면 코스닥이 잘림)

# ===== 매매 엔진(멍거 리스크 실드) — 기본 10분 주기, 주문은 내지 않음 =====
# ENGINE_INTERVAL_SEC=600
# MDD_LIMIT_PCT=15        # 최고점 대비 -15% → 자동 매수 잠금(서킷 브레이커)
# MAX_STOCK_PCT=5         # 단일 종목 최대 매수금액 = 자산의 5%
# CASH_FLOOR_PCT=25       # 현금 비중 25% 미만이면 매수 시그널 무시
# BUY_SCORE_MIN=70        # 2단계 필터 최종 점수 컷
# INVERSION_MAX_PER_CYCLE=5
# INVERSION_FRESH_SEC=604800  # AI 역방향 감점 재검증 주기(기본 1주 — 토큰 절약)
# --- 자동매매·주문지시 (브로커 분리: 자동=한투, 수동=토스 앱) ---
# AUTO_TRADE_BROKER=kis      # kis(기본) | toss — 자동매수·텔레그램 주문이 나가는 계좌
# KIS_TRADING_ENABLED=false  # 한투 주문 게이트. KIS_ACCOUNT=12345678-01 형식 필수.
#                            # KIS_PAPER=true면 모의투자 주문(안전 리허설), false면 실전
# KIS_MAX_ORDER_KRW=100000   # 한투 주문당 안전 상한
# AUTO_TRADE_ENABLED=false   # true면 필터 통과 신규 종목을 추천 매수가에 자동 지정가 매수
#                            # (⚠️ 이중 옵트인: 브로커 매매 플래그도 true여야 실제 동작)
# AUTO_TRADE_COOLDOWN_SEC=604800   # 같은 종목 자동 재매수 금지(7일)
# 텔레그램 주문지시: 봇에게 '도움말' 전송 — 매수/매도는 '확인 N' 회신 필수(등록 chat_id만)

# ===== 텔레그램 (일일 브리핑·알림) =====
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# BRIEFING_INTERVAL_SEC=86400
# BRIEFING_DRIP_BUDGET=0     # 배당 정기적립 월예산(원). 0=미사용

# ===== AI 4대 거장 리서치 — 둘 중 하나 =====
# (A) 구독 무과금: Claude Code 설치+로그인 후 아래 ON (API 키 불필요, 구독 한도 내)
# RESEARCH_USE_CLI=false
# RESEARCH_CLI_BIN=claude
# (B) API 종량과금: console.anthropic.com 키 (구독과 별도 결제)
# ANTHROPIC_API_KEY=
# 공통
# RESEARCH_MODEL=claude-opus-4-8
# RESEARCH_INTERVAL_SEC=604800   # 관심종목 정기 AI 분석 주기(기본 1주 — 토큰 절약)
#   ⚠️ .env에 86400 등 낮은 값이 남아 있으면 코드 기본(1주)을 덮어써 매일 재분석됩니다.
#   ⚠️ .env 변경은 `docker compose restart`로는 반영 안 됨 — `up -d` 필요. 호스트 research는 재시작 필요.
# --- AI 아침 점검(포트폴리오 코치): 실보유 비중 기준 종목별 판정 + 한 줄 결론 ---
# COACH_ENABLED=true
# COACH_HOUR_KST=8        # 매일 이 시각(KST)에 텔레그램 자동 발송(하루 1콜)

# --- ADR 괴리율(코치 아침 점검에 표시) ---
# 형식 "본주코드:후보티커1|후보티커2:비율(1 ADR당 본주 수)". 후보 중 토스가 잡히는 티커 자동 채택.
# SK하이닉스 ADR이 SKHY로 보이면 아래처럼. 비율은 본주가 대비 (ADR$×환율)이 맞도록 조정.
# ADR_MAP=000660:SKHY|SKHYY|SKH:1
