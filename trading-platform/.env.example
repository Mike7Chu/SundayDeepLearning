# ===== 공통 =====
# API 호스트 포트 (8000이 이미 점유된 경우 변경. OMV 등과 충돌 회피용 기본 8090)
API_PORT=8090

# Redis
REDIS_URL=redis://redis:6379/0

# 시세 수집 주기(초)
COLLECT_INTERVAL_SEC=5
# 환율 갱신 주기(초)
FX_INTERVAL_SEC=300
# 환율 조회 실패 시 폴백 USD/KRW
FX_USDKRW_FALLBACK=1380

# ===== TimescaleDB (선택, Phase 1 후반) =====
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=trading
POSTGRES_USER=trader
POSTGRES_PASSWORD=change-me

# ===== 텔레그램 (Phase 2) =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== 거래소 API 키 (Phase 3+, 출금권한 없는 읽기/거래 키만) =====
# UPBIT_API_KEY=
# UPBIT_SECRET=
# BINANCE_API_KEY=
# BINANCE_SECRET=

# ===== 한국투자증권 KIS (Phase 5) =====
# KIS_APP_KEY=
# KIS_APP_SECRET=
# KIS_ACCOUNT=
# KIS_PAPER=true

# ===== AI 가치투자 리서치 (Addendum 9) — 둘 중 하나 =====
# (A) 구독 무과금: Claude Code 설치+로그인 후 아래 ON (API 키 불필요, 구독 한도 내)
# RESEARCH_USE_CLI=false
