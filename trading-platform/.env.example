# ===== 공통 =====
# API 호스트 포트 (8000이 이미 점유된 경우 변경. OMV 등과 충돌 회피용 기본 8090)
API_PORT=8090

# Redis
REDIS_URL=redis://redis:6379/0

# 시세 수집 주기(초)
COLLECT_INTERVAL_SEC=5
# 환율 갱신 주기(초)
FX_INTERVAL_SEC=300
# 환율 조회 실패 시 폴백 USD/KRW
FX_USDKRW_FALLBACK=1380

# ===== TimescaleDB (선택, Phase 1 후반) =====
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=trading
POSTGRES_USER=trader
POSTGRES_PASSWORD=change-me

# ===== 텔레그램 (Phase 2) =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

